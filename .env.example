# Base path served by GitHub Pages. For a repo `atomic-chat-admin` under a user
# account this should be `/atomic-chat-admin/`. For a `<user>.github.io` repo,
# leave `/`.
VITE_BASE_PATH=/

# GitHub repo that stores the mobile-app catalog (`models.json`).
# The admin panel reads/writes this file via the Contents API using the PAT
# you paste on sign-in. The mobile app reads it via jsDelivr:
#   https://cdn.jsdelivr.net/gh/<owner>/<repo>@<branch>/<path>
VITE_DATA_REPO_OWNER=V-Babayan
VITE_DATA_REPO_NAME=atomic-chat-mobile-data
VITE_DATA_FILE_PATH=models.json
VITE_DATA_BRANCH=main

# Set to `true` to use the in-browser mock client (seeded from the mobile
# app snapshot, persisted in localStorage). Handy for local dev without
# hitting GitHub.
VITE_USE_MOCK=false
