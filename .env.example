# Backend API base URL. Example: https://api.atomic-chat.com
VITE_API_BASE_URL=http://localhost:3000

# Base path served by GitHub Pages. For a repo `atomic-chat-admin` under a user
# account this should be `/atomic-chat-admin/`. For a `<user>.github.io` repo,
# leave `/`.
VITE_BASE_PATH=/

# UI-gate credentials for the login form. Note: these are bundled into the
# static build and visible in devtools — keep the repo private and rotate on
# leaks.
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=changeme

# Bearer token sent to the backend `AdminTokenGuard`. Also bundled.
VITE_ADMIN_TOKEN=replace-me

# Set to `true` to use the in-browser mock client (seeded from the mobile
# app snapshot, persisted in localStorage). Handy for local dev while the
# backend endpoints (Sprint 2) are not ready.
VITE_USE_MOCK=true
